{
  "name": "parabank-playwright-framework",
  "version": "1.0.0",
  "description": "Playwright + TypeScript + Cucumber BDD + Allure automation framework for ParaBank",
  "private": true,
  "scripts": {
    "test": "node ./scripts/run-cucumber.mjs",
    "test:smoke": "node ./scripts/run-cucumber.mjs --tags @smoke",
    "test:headed": "node ./scripts/run-cucumber.mjs --headed",
    "test:firefox": "node ./scripts/run-cucumber.mjs --browser firefox",
    "test:debug": "node ./scripts/run-cucumber.mjs --headed --slowmo 300",
    "typecheck": "tsc --noEmit",
    "pw:install": "npx playwright install chromium",
    "pw:install:all": "npx playwright install",
    "report:generate": "node ./scripts/generate-allure.mjs",
    "report:open": "node ./scripts/open-allure.mjs"
  },
  "keywords": [
    "playwright",
    "typescript",
    "cucumber",
    "bdd",
    "allure"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^11.3.0",
    "@cucumber/messages": "^32.3.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-commandline": "^2.38.1",
    "allure-cucumberjs": "^3.7.1",
    "allure-js-commons": "^3.7.1",
    "dotenv": "^17.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
